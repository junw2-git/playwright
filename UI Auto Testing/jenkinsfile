pipeline {

    agent any

    stages {

        stage('Checkout') {
            steps {
                git 'https://github.com/junw2-git/playwright.git'
            }
        }

        stage('Install Dependencies') {
            steps {
                sh "cd /var/lib/jenkins/workspace/Playwright/'UI Auto Testing' "
                sh 'pip install -r requirements.txt'
                sh 'playwright install'
            }
        }

        stage('Run Tests') {
            steps {
                sh 'pytest'
            }
        }

    }

}
