pipeline {

    agent any

    stages {

        stage('Checkout') {
            steps {
                  sh "echo 'ignore git steps' "
                  //git 'https://github.com/junw2-git/playwright.git'
            }
        }

        stage('Install Dependencies') {
            steps {
                sh "cd ${WORKSPACE}/'UI Auto Testing' "
                sh 'pip3 install -r requirements.txt --user'
                sh 'playwright install'
            }
        }

        stage('Run Tests') {
            steps {
                sh 'pytest'
            }
        }

    }

}
