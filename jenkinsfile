pipeline {

    agent any

    stages {

        stage('Checkout') {
            steps {
                  sh "echo 'ignore git steps' "
                  //git 'https://github.com/junw2-git/playwright.git'
            }
        }

        stage('Install Dependencies') {
            steps {
                sh 'pip3 install pytest pytest-playwright pytest-html playwright allure-pytest --user'
                sh 'playwright install'
            }
        }

        stage('Run Tests') {
            steps {
                sh '''
                  cd "${WORKSPACE}/UI Auto Testing "
                  ls -al
                  pytest test_monitor_network_request.py test_inventory_page_performance.py test_api_response_time.py test_page_load_time.py \
                    --html=report.html
                  '''
            }
        }

    }

}
