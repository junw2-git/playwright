pipeline {

    agent any

    stages {

        stage('Checkout') {
            steps {
                  sh "echo 'ignore git steps' "
                  //git 'https://github.com/junw2-git/playwright.git'
            }
        }

        stage('Install Dependencies') {
            steps {
                sh 'pip3 install pytest pytest-playwright pytest-html playwright allure-pytest pytest-xdist --user'
                sh 'playwright install'
            }
        }

        stage('Run Tests') {
            steps {
                sh '''
                  cd "${WORKSPACE}/UI Auto Testing"
                  pytest -n auto --html=report.html
                  '''
            }
        }

    }

}
